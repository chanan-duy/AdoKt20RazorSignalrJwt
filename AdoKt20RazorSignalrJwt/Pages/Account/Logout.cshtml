@page
@model LogoutModel
@{
	ViewData["Title"] = "logout";
}

<div class="auth-page">
	<div class="card auth-card">
		<div class="card-body p-4">
			<h1 class="h3 mb-3">logout</h1>

			@if (User.Identity?.IsAuthenticated == true)
			{
				<p class="text-secondary mb-4">sign out from the current user session.</p>

				<form method="post">
					<button type="submit" class="btn btn-primary">logout</button>
				</form>
			}
			else
			{
				<p class="text-secondary mb-3">you are not signed in.</p>
				<a class="btn btn-outline-secondary" asp-page="/Index">back</a>
			}
		</div>
	</div>
</div>
